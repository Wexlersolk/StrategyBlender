      "lots": "float(self.p(\"mmLots\"))",
      "name": "long_breakout",
      "order_type": "buy_stop",
      "price": "float(df[\"highest_level\"].iloc[i - 1])",
      "side": "long",
      "stop_loss": "float(df[\"highest_level\"].iloc[i - 1]) - float(df[\"atr\"].iloc[i - 1]) * float(self.p(\"StopLossATR\"))",
      "take_profit": "float(df[\"highest_level\"].iloc[i - 1]) + float(df[\"atr\"].iloc[i - 1]) * float(self.p(\"ProfitTargetATR\"))",
      "trail_activation": null,
      "trail_dist": null,
      "when": "bool(df[\"entry_signal\"].iloc[i]) and (abs(float(df[\"highest_level\"].iloc[i - 1]) - ctx.open) / max(abs(ctx.open), 1e-9) * 100.0 <= float(self.p(\"MaxDistancePct\")))"
    }
  ],
